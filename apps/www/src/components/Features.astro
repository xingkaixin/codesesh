---
import { copy, type Locale } from "../data/landing";
import HeadingText from "./HeadingText.astro";
import Icon from "./Icon.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = copy[locale].features;

// 阶段色按序列语义映射：发现=读、组织=写、找回=用户、复盘=Agent
const stageColors = ["--timeline-tool-read", "--timeline-tool-write", "--timeline-user", "--timeline-agent"];
---

<section class="px-6 py-24" aria-labelledby="features-heading">
  <div class="mx-auto max-w-6xl">
    <h2
      id="features-heading"
      class="landing-heading max-w-2xl text-3xl font-semibold leading-tight tracking-tight text-[var(--console-accent-strong)] md:text-4xl"
    >
      <HeadingText value={t.title} />
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-7 text-[var(--console-muted)]">{t.body}</p>

    <div class="mt-14 space-y-12">
      {
        t.groups.map((group, index) => (
          <article class="border-l-2 pl-6 md:pl-8" style={`border-color: var(${stageColors[index]})`}>
            <div class="grid gap-6 md:grid-cols-[14rem_minmax(0,1fr)] md:gap-10">
              <div>
                <h3 class="text-xl font-semibold tracking-tight text-[var(--console-text)]">
                  {group.title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-[var(--console-muted)]">
                  {group.description}
                </p>
              </div>

              <ul class="grid gap-x-8 gap-y-6 sm:grid-cols-2">
                {group.items.map((item) => (
                  <li class="grid grid-cols-[2rem_1fr] gap-3">
                    <div class="flex size-8 items-center justify-center rounded-[2px] border border-[var(--console-border)] bg-[var(--console-surface-muted)]">
                      <Icon name={item.icon} class="size-4 text-[var(--console-accent)]" />
                    </div>
                    <div>
                      <h4 class="text-sm font-semibold text-[var(--console-text)]">
                        {item.title}
                      </h4>
                      <p class="mt-1 text-sm leading-6 text-[var(--console-muted)]">
                        {item.description}
                      </p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
