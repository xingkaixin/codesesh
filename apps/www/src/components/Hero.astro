---
import { copy, type Locale } from "../data/landing";
import HeadingText from "./HeadingText.astro";
import Icon from "./Icon.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = copy[locale].hero;

const laneColors = {
  user: "--timeline-user",
  agent: "--timeline-agent",
  read: "--timeline-tool-read",
  write: "--timeline-tool-write",
  execute: "--timeline-tool-execute",
} as const;
type LaneKey = keyof typeof laneColors;

const lanes: { c: LaneKey; w: number }[][] = [
  [
    { c: "user", w: 16 },
    { c: "agent", w: 34 },
    { c: "read", w: 10 },
    { c: "agent", w: 18 },
  ],
  [
    { c: "agent", w: 12 },
    { c: "read", w: 8 },
    { c: "write", w: 22 },
    { c: "agent", w: 26 },
  ],
  [
    { c: "user", w: 10 },
    { c: "agent", w: 20 },
    { c: "execute", w: 14 },
    { c: "read", w: 8 },
    { c: "agent", w: 24 },
  ],
  [
    { c: "write", w: 18 },
    { c: "execute", w: 10 },
    { c: "agent", w: 30 },
    { c: "read", w: 12 },
  ],
  [
    { c: "user", w: 14 },
    { c: "agent", w: 26 },
    { c: "write", w: 10 },
    { c: "execute", w: 8 },
    { c: "agent", w: 20 },
  ],
  [
    { c: "agent", w: 22 },
    { c: "read", w: 10 },
    { c: "write", w: 14 },
    { c: "agent", w: 28 },
  ],
  [
    { c: "user", w: 12 },
    { c: "agent", w: 18 },
    { c: "read", w: 8 },
    { c: "execute", w: 12 },
    { c: "agent", w: 22 },
  ],
  [
    { c: "agent", w: 26 },
    { c: "write", w: 12 },
    { c: "read", w: 8 },
    { c: "agent", w: 20 },
  ],
];

const legend: LaneKey[] = ["user", "agent", "read", "write", "execute"];
---

<section class="bg-grid px-6 pb-20 pt-16 md:pt-24">
  <div class="mx-auto grid max-w-6xl min-w-0 items-center gap-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(20rem,0.95fr)]">
    <div class="min-w-0 text-left">
      <h1 class="landing-heading max-w-3xl text-4xl font-semibold leading-[1.1] tracking-tight text-[var(--console-accent-strong)] md:text-5xl">
        <HeadingText value={t.title} />
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-7 text-[var(--console-muted)] md:text-lg md:leading-8">
        {t.body}
      </p>

      <div class="mt-10 max-w-xl border-y border-[var(--console-border)] py-5">
        <p class="console-mono text-xs font-semibold uppercase tracking-[0.12em] text-[var(--console-muted)]">
          {t.commandTitle}
        </p>
        <div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center">
          <code class="console-mono flex-1 rounded-[2px] border border-[var(--console-border-strong)] bg-white px-4 py-3 text-sm text-[var(--console-text)]">
            $ {t.command}
          </code>
          <button
            type="button"
            data-copy-command={t.command}
            data-copy-label={t.copyCommand}
            data-copied-label={t.copied}
            data-copy-failed-label={t.copyFailed}
            class="pressable console-mono inline-flex items-center justify-center gap-2 rounded-[2px] bg-[var(--console-accent-strong)] px-4 py-3 text-xs font-semibold text-white hover:bg-black"
          >
            <span class="copy-icon-stack inline-grid">
              <span data-copy-icon="idle" data-active="true"><Icon name="copy" class="size-4" /></span>
              <span data-copy-icon="done"><Icon name="check" class="size-4" /></span>
            </span>
            <span data-copy-text>{t.copyCommand}</span>
          </button>
        </div>
        <span class="sr-only" aria-live="polite" data-copy-status></span>
        <p class="mt-3 text-sm leading-6 text-[var(--console-muted)]">{t.runtime}</p>
      </div>
    </div>

    <div class="min-w-0">
      <div
        aria-hidden="true"
        class="rounded-sm border border-[var(--console-border-strong)] bg-white p-5 shadow-[0_1px_2px_rgba(0,0,0,0.04)]"
      >
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 border-b border-[var(--console-border)] pb-4">
          {
            legend.map((key) => (
              <span class="flex items-center gap-1.5">
                <span class="size-2 rounded-[1px]" style={`background: var(${laneColors[key]})`} />
                <span class="console-mono text-[10px] text-[var(--console-muted)]">{key}</span>
              </span>
            ))
          }
        </div>
        <div class="mt-5 flex flex-col gap-2.5">
          {
            lanes.map((row, rowIndex) => (
              <div class="tl-row flex h-3.5 gap-1" style={`--tl-i: ${rowIndex}`}>
                {row.map((segment) => (
                  <span
                    class="h-full rounded-[2px]"
                    style={`width: ${segment.w}%; background: var(${laneColors[segment.c]})`}
                  />
                ))}
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function copyText(value: string) {
    try {
      await navigator.clipboard.writeText(value);
      return true;
    } catch {
      try {
        const textarea = document.createElement("textarea");
        textarea.value = value;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.top = "-9999px";
        document.body.append(textarea);
        textarea.select();
        const execCommand = Reflect.get(document, "execCommand");
        const copied =
          typeof execCommand === "function" && execCommand.call(document, "copy") === true;
        textarea.remove();
        return copied;
      } catch {
        return false;
      }
    }
  }

  document.querySelectorAll<HTMLButtonElement>("[data-copy-command]").forEach((button) => {
    const command = button.dataset.copyCommand;
    const copyLabel = button.dataset.copyLabel ?? "";
    const copiedLabel = button.dataset.copiedLabel ?? "";
    const copyFailedLabel = button.dataset.copyFailedLabel ?? "";
    const text = button.querySelector("[data-copy-text]");
    const status = button.parentElement?.parentElement?.querySelector("[data-copy-status]");
    const idleIcon = button.querySelector<HTMLElement>('[data-copy-icon="idle"]');
    const doneIcon = button.querySelector<HTMLElement>('[data-copy-icon="done"]');

    if (!command || !text || !idleIcon || !doneIcon) return;

    let timer: number;

    button.addEventListener("click", async () => {
      const copied = await copyText(command);
      const feedback = copied ? copiedLabel : copyFailedLabel;
      text.textContent = feedback;
      if (status) status.textContent = feedback;
      idleIcon.dataset.active = String(!copied);
      doneIcon.dataset.active = String(copied);

      window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        text.textContent = copyLabel;
        idleIcon.dataset.active = "true";
        doneIcon.dataset.active = "false";
      }, 2000);
    });
  });
</script>
