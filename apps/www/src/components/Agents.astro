---
import { agents, copy, type Locale } from "../data/landing";
import HeadingText from "./HeadingText.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = copy[locale].agents;
---

<section
  class="border-t border-[var(--console-border)] bg-[var(--console-surface)] px-6 py-20"
  aria-labelledby="agents-heading"
>
  <div class="mx-auto max-w-4xl text-center">
    <h2
      id="agents-heading"
      class="landing-heading text-3xl font-semibold leading-tight tracking-tight text-[var(--console-accent-strong)] md:text-4xl"
    >
      <HeadingText value={t.title} />
    </h2>
    <p class="mt-4 text-base leading-7 text-[var(--console-muted)]">{t.body}</p>

    <ul class="mt-10 flex flex-wrap justify-center gap-3">
      {
        agents.map((agent) => (
          <li class="flex items-center gap-2.5 rounded-[2px] border border-[var(--console-border)] bg-[var(--console-surface-muted)] px-4 py-2.5">
            <img
              src={agent.icon}
              alt={agent.name}
              width="24"
              height="24"
              class="size-6 object-contain"
              loading="lazy"
            />
            <span class="console-mono text-xs font-semibold text-[var(--console-text)]">
              {agent.name}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
