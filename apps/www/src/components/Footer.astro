---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--console-border)] px-6 py-8">
  <div class="mx-auto flex max-w-6xl items-center justify-between">
    <span class="console-mono text-xs text-[var(--console-muted)]">CodeSesh</span>
    <span class="console-mono text-xs text-[var(--console-muted)]">&copy; {year}</span>
  </div>
</footer>
