{
  "name": "codesesh",
  "version": "0.1.0",
  "bin": {
    "codesesh": "dist/index.js"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-web-dist.js",
    "release": "tsup && node scripts/copy-web-dist.js",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@codesesh/core": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "hono": "^4.7.4",
    "open": "^10.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  }
}
