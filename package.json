{
  "name": "codesesh-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "serve": "node --watch packages/cli/dist/index.js",
    "clean": "turbo run clean",
    "lint": "oxlint packages/ apps/",
    "lint:fix": "oxlint packages/ apps/ --fix",
    "format": "oxfmt --write packages/ apps/",
    "format:check": "oxfmt --check packages/ apps/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
